@page
@model CommitteeConfigurationModel
@{
    ViewData["CommitteePageTitle"] = "Configuration";
}

<div class="committee-page">
<partial name="_CommitteeHeader" />
<partial name="_CommitteeNav" />

<h5>Cohort</h5>
<div class="table-responsive mb-3">
    <table class="table table-sm table-bordered align-middle">
        <thead>
            <tr>
                <th>Description</th>
                <th>Start</th>
                <th>End</th>
                <th>Active</th>
                <th>Final Due Date</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var c in Model.Cohorts)
            {
                <tr>
                    <td>@c.description</td>
                    <td>@c.startDate?.ToString("yyyy-MM-dd")</td>
                    <td>@c.endDate?.ToString("yyyy-MM-dd")</td>
                    <td>@c.isActive</td>
                    <td>@c.finalReportDueDate?.ToString("yyyy-MM-dd")</td>
                </tr>
            }
        </tbody>
    </table>
</div>

<h5>Student Access</h5>
<div class="alert alert-warning mb-0">
    Placeholder: `studentaccess` is in database design, but no model/page logic is mapped yet in `ApplicationDbContext`.
</div>
</div>

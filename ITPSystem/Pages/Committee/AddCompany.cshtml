@page
@model CommitteeAddCompanyModel
@{
    ViewData["CommitteePageTitle"] = "Add Company";
}

<div class="committee-page">
<partial name="_CommitteeHeader" />
<partial name="_CommitteeNav" />

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0">Add Company</h5>
    <a asp-page="/Committee/Companies" class="btn btn-sm btn-outline-secondary">Back to Company List</a>
</div>

<div class="card">
    <div class="card-body">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>
            <div class="row g-2">
                <div class="col-md-4">
                    <label asp-for="Input.name" class="form-label">Name</label>
                    <input asp-for="Input.name" class="form-control form-control-sm" />
                </div>
                <div class="col-md-4">
                    <label asp-for="Input.address1" class="form-label">Address 1</label>
                    <input asp-for="Input.address1" class="form-control form-control-sm" />
                </div>
                <div class="col-md-2">
                    <label asp-for="Input.address2" class="form-label">Address 2</label>
                    <input asp-for="Input.address2" class="form-control form-control-sm" />
                </div>
                <div class="col-md-2">
                    <label asp-for="Input.address3" class="form-label">Address 3</label>
                    <input asp-for="Input.address3" class="form-control form-control-sm" />
                </div>
                <div class="col-md-2">
                    <label asp-for="Input.regNo" class="form-label">Reg No</label>
                    <input asp-for="Input.regNo" class="form-control form-control-sm" />
                </div>
                <div class="col-md-2">
                    <label asp-for="Input.vacancyLevel" class="form-label">Vacancy Level</label>
                    <select asp-for="Input.vacancyLevel" class="form-select form-select-sm">
                        <option value="">-- Select --</option>
                        <option value="Diploma">Diploma</option>
                        <option value="Degree">Degree</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label asp-for="Input.website" class="form-label">Website</label>
                    <input asp-for="Input.website" class="form-control form-control-sm" />
                </div>
                <div class="col-md-3">
                    <label asp-for="Input.remark" class="form-label">Remark</label>
                    <input asp-for="Input.remark" class="form-control form-control-sm" />
                </div>
                <div class="col-md-1">
                    <label asp-for="Input.status" class="form-label">Status</label>
                    <select asp-for="Input.status" class="form-select form-select-sm">
                        <option value="1">1</option>
                        <option value="0">0</option>
                    </select>
                </div>
                <div class="col-md-1">
                    <label asp-for="Input.visibility" class="form-label">Visibility</label>
                    <select asp-for="Input.visibility" class="form-select form-select-sm">
                        <option value="1">1</option>
                        <option value="0">0</option>
                    </select>
                </div>
                <div class="col-md-12 mt-2">
                    <button type="submit" class="btn btn-success">Add Company</button>
                    <a asp-page="/Committee/Companies" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </div>
        </form>
    </div>
</div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

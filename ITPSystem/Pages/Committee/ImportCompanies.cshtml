@page
@model CommitteeImportCompaniesModel
@{
    ViewData["CommitteePageTitle"] = "Import Company";
}

<div class="committee-page">
<partial name="_CommitteeHeader" />
<partial name="_CommitteeNav" />

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0">Import Company</h5>
    <a asp-page="/Committee/Companies" class="btn btn-sm btn-outline-secondary">Back to Company List</a>
</div>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="alert alert-info">@Model.StatusMessage</div>
}

<div class="card" style="max-width:920px;">
    <div class="card-body">
        <p class="text-muted mb-2">
            CSV columns order:
            <code>name,address1,address2,address3,regNo,vacancyLevel,website,remark,status,visibility</code>
        </p>
        <form method="post" enctype="multipart/form-data">
            <div class="mb-3">
                <label class="form-label">Company CSV File</label>
                <input asp-for="CsvFile" type="file" accept=".csv,text/csv" class="form-control" />
            </div>
            <button type="submit" class="btn btn-primary">Import Companies</button>
            <a asp-page="/Committee/Companies" class="btn btn-outline-secondary">Cancel</a>
        </form>
    </div>
</div>
</div>

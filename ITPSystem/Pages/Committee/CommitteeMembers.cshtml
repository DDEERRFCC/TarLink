@page
@model CommitteeMembersModel
@{
    ViewData["CommitteePageTitle"] = "Committee Member";
}

<div class="committee-page">
<partial name="_CommitteeHeader" />
<partial name="_CommitteeNav" />

<div class="table-responsive">
    <table class="table table-sm table-bordered align-middle">
        <thead>
            <tr>
                <th>Username</th>
                <th>Email</th>
                <th>Active</th>
                <th>Locked</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var m in Model.Members)
            {
                <tr>
                    <td>@m.username</td>
                    <td>@m.email</td>
                    <td>@m.is_active</td>
                    <td>@m.is_locked</td>
                </tr>
            }
        </tbody>
    </table>
</div>
</div>

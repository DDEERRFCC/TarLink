@page
@model CommitteeCompaniesModel
@{
    ViewData["CommitteePageTitle"] = "Company";
}

<div class="committee-page">
<partial name="_CommitteeHeader" />
<partial name="_CommitteeNav" />

<div class="table-responsive">
    <table class="table table-sm table-bordered align-middle">
        <thead>
            <tr>
                <th>Name</th>
                <th>Address</th>
                <th>Status</th>
                <th>Visibility</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var c in Model.Companies)
            {
                <tr>
                    <td>@c.name</td>
                    <td>@string.Join(", ", new[] { c.address1, c.address2, c.address3 }.Where(x => !string.IsNullOrWhiteSpace(x)))</td>
                    <td>@c.status</td>
                    <td>@c.visibility</td>
                </tr>
            }
        </tbody>
    </table>
</div>
</div>

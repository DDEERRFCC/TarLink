@page
@model CommitteeStudentsModel
@{
    ViewData["CommitteePageTitle"] = "Student List";
}

<div class="committee-page">
<partial name="_CommitteeHeader" />
<partial name="_CommitteeNav" />

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="alert alert-success mb-3">@Model.StatusMessage</div>
}

<div class="card mb-3">
    <div class="card-body">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-4">
                <label class="form-label">Search</label>
                <input name="Search" value="@Model.Search" class="form-control form-control-sm" placeholder="Student ID, name, email, programme, company" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Status</label>
                <select name="StatusFilter" class="form-select form-select-sm">
                    <option value="">All</option>
                    <option value="pending" selected="@(Model.StatusFilter == "pending")">pending</option>
                    <option value="approved" selected="@(Model.StatusFilter == "approved")">approved</option>
                    <option value="rejected" selected="@(Model.StatusFilter == "rejected")">rejected</option>
                    <option value="withdrawn" selected="@(Model.StatusFilter == "withdrawn")">withdrawn</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">Cohort</label>
                <select name="CohortFilter" class="form-select form-select-sm">
                    <option value="">All</option>
                    @foreach (var c in Model.CohortOptions)
                    {
                        <option value="@c.Value" selected="@(Model.CohortFilter?.ToString() == c.Value)">@c.Text</option>
                    }
                </select>
            </div>
            <div class="col-md-2 d-flex gap-2">
                <button type="submit" class="btn btn-sm btn-primary w-100">Apply</button>
                <a asp-page="/Committee/Students" class="btn btn-sm btn-outline-secondary w-100">Reset</a>
            </div>
        </form>
        <div class="mt-2 small text-muted">
            Number of students: @Model.FilteredStudents / @Model.TotalStudents
        </div>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-sm table-bordered align-middle">
        <thead>
            <tr>
                <th>No.</th>
                <th>Student ID</th>
                <th>Name</th>
                <th>Gender</th>
                <th>Programme</th>
                <th>Contact</th>
                <th>Cohort</th>
                <th>Status</th>
                <th>Last Update</th>
                <th>Company</th>
                <th>UC Supervisor</th>
                <th style="width: 110px;">Action</th>
            </tr>
        </thead>
        <tbody>
            @{
                var no = 1;
            }
            @foreach (var s in Model.Students)
            {
                <tr>
                    <td>@no</td>
                    <td>@s.studentID</td>
                    <td>@s.studentName</td>
                    <td>
                        @{
                            var genderLabel = (s.gender ?? "O").ToUpperInvariant() switch
                            {
                                "M" => "Male",
                                "F" => "Female",
                                _ => "Other"
                            };
                        }
                        @genderLabel
                    </td>
                    <td>@(string.IsNullOrWhiteSpace(s.programme) ? "-" : s.programme)</td>
                    <td>
                        <div>@s.studentEmail</div>
                        <div class="text-muted small">@(!string.IsNullOrWhiteSpace(s.permanentContact) ? s.permanentContact : "-")</div>
                    </td>
                    <td>@(s.Cohort?.description ?? s.cohortId.ToString())</td>
                    <td>@s.applyStatus</td>
                    <td>@s.updated_at.ToString("yyyy-MM-dd HH:mm")</td>
                    <td>@(s.comName ?? "-")</td>
                    <td>@(s.ucSupervisor ?? "-")</td>
                    <td>
                        <a class="btn btn-sm btn-primary"
                           asp-page="/Committee/StudentDetails"
                           asp-route-applicationId="@s.application_id">Details</a>
                    </td>
                </tr>
                no++;
            }
        </tbody>
    </table>
</div>
</div>

@page
@model CommitteeUnregisteredStudentsModel
@{
    ViewData["CommitteePageTitle"] = "Unregistered Student";
}

<div class="committee-page">
<partial name="_CommitteeHeader" />
<partial name="_CommitteeNav" />

<div class="table-responsive">
    <table class="table table-sm table-bordered align-middle">
        <thead>
            <tr>
                <th>User ID</th>
                <th>Student ID</th>
                <th>Name</th>
                <th>Email</th>
                <th>Cohort</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.UnregisteredStudents.Count == 0)
            {
                <tr><td colspan="5" class="text-center text-muted">No unregistered (inactive) students.</td></tr>
            }
            else
            {
                @foreach (var s in Model.UnregisteredStudents)
                {
                    <tr>
                        <td>@s.UserId</td>
                        <td>@s.StudentId</td>
                        <td>@s.Name</td>
                        <td>@s.Email</td>
                        <td>@s.Cohort</td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>
</div>

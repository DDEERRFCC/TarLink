@page
@model CommitteeProgressEvaluationModel
@{
    ViewData["CommitteePageTitle"] = "Progress Report & Evaluation";
}

<div class="committee-page">
<partial name="_CommitteeHeader" />
<partial name="_CommitteeNav" />

<div class="table-responsive">
    <table class="table table-sm table-bordered align-middle">
        <thead>
            <tr>
                <th>Student</th>
                <th>Report</th>
                <th>Due Date</th>
                <th>Status</th>
                <th>Evaluation</th>
                <th>Remark</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Items)
            {
                <tr>
                    <td>@item.StudentName (@item.StudentId)</td>
                    <td>@item.ReportTitle</td>
                    <td>@item.DueDate.ToString("yyyy-MM-dd")</td>
                    <td>@Model.GetStatusText(item.Status)</td>
                    <td>@item.EvaluationSummary</td>
                    <td>@item.Remark</td>
                </tr>
            }
        </tbody>
    </table>
</div>
</div>

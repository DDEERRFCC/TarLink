@page
@model CommitteeStudentResumesModel
@{
    ViewData["CommitteePageTitle"] = "Student Resume / CV";
}

<div class="committee-page">
<partial name="_CommitteeHeader" />
<partial name="_CommitteeNav" />

<p class="text-muted">Using `otherEvidence` as the current resume/CV source. Showing all students as a list.</p>

@if (Model.Students.Count == 0)
{
    <div class="alert alert-secondary mb-0">No student records found.</div>
}
</div>
else
{
    <div class="list-group">
        @foreach (var s in Model.Students)
        {
            var hasCv = !string.IsNullOrWhiteSpace(s.otherEvidence);
            <div class="list-group-item d-flex justify-content-between align-items-start gap-3">
                <div>
                    <div class="fw-semibold">@s.studentName (@s.studentID)</div>
                    <div class="text-muted small">@s.studentEmail</div>
                    <div class="small mt-1">
                        <span class="text-muted">Resume/CV:</span>
                        @if (hasCv)
                        {
                            <span>@s.otherEvidence</span>
                        }
                        else
                        {
                            <span class="text-danger">Not uploaded</span>
                        }
                    </div>
                </div>
                <div>
                    @if (hasCv)
                    {
                        <span class="badge text-bg-success">Available</span>
                    }
                    else
                    {
                        <span class="badge text-bg-secondary">Missing</span>
                    }
                </div>
            </div>
        }
    </div>
}

@page
@model CommitteeStudentResumesModel
@{
    ViewData["CommitteePageTitle"] = "Student Resume / CV";
}

<div class="committee-page">
<partial name="_CommitteeHeader" />
<partial name="_CommitteeNav" />

<p class="text-muted">Showing latest uploaded resume/CV from `studentcv` for each student.</p>

@if (Model.Students.Count == 0)
{
    <div class="alert alert-secondary mb-0">No student records found.</div>
}
else
{
    <div class="list-group">
        @foreach (var s in Model.Students)
        {
            var hasCv = s.Cv != null && !string.IsNullOrWhiteSpace(s.Cv.file_path);
            var displayName = hasCv
                ? (!string.IsNullOrWhiteSpace(s.Cv!.file_name) ? s.Cv.file_name : System.IO.Path.GetFileName(s.Cv.file_path))
                : null;
            <div class="list-group-item d-flex justify-content-between align-items-start gap-3">
                <div>
                    <div class="fw-semibold">@s.Student.studentName (@s.Student.studentID)</div>
                    <div class="text-muted small">@s.Student.studentEmail</div>
                    <div class="small mt-1">
                        <span class="text-muted">Resume/CV:</span>
                        @if (hasCv)
                        {
                            <span>@displayName</span>
                        }
                        else
                        {
                            <span class="text-danger">Not uploaded</span>
                        }
                    </div>
                </div>
                <div>
                    @if (hasCv)
                    {
                        <a class="btn btn-sm btn-outline-primary me-1"
                           asp-page-handler="ResumeFile"
                           asp-route-applicationId="@s.Student.application_id"
                           asp-route-download="false"
                           target="_blank" rel="noopener">View</a>
                        <a class="btn btn-sm btn-primary"
                           asp-page-handler="ResumeFile"
                           asp-route-applicationId="@s.Student.application_id"
                           asp-route-download="true">Download</a>
                    }
                    else
                    {
                        <span class="badge text-bg-secondary">Missing</span>
                    }
                </div>
            </div>
        }
    </div>
}
</div>

@page
@model OwnCompanyRequestModel
@{
    ViewData["Title"] = "Own Company Request";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap mb-3">
        <div>
            <h2 class="mb-1">I Wish To Apply To A Company Of My Own Choice</h2>
            <p class="text-muted mb-0">Submit your company details for ITP committee review.</p>
        </div>
        <a asp-page="/Student/Dashboard" class="btn btn-outline-secondary btn-sm">Back to Dashboard</a>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="alert alert-success">@Model.StatusMessage</div>
    }

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger">
            <div class="fw-semibold mb-1">Please fix the following:</div>
            <ul class="mb-0">
                @foreach (var entry in ViewData.ModelState.Values)
                {
                    foreach (var error in entry.Errors)
                    {
                        <li>@error.ErrorMessage</li>
                    }
                }
            </ul>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-body">
            <h5 class="card-title">Notes</h5>
            <ul>
                <li>It is students responsibility to request the company to register at CareeR<sup>e</sup>X (<a href="https://www.tarc.edu.my/jobs/" target="_blank" rel="noopener">https://www.tarc.edu.my/jobs/</a>).</li>
                <li>ITP committee will only approve the company after recieved the application AND the company has fulfilled the university requiredments.</li>
                <li>You do not have any relationship with the managers / supervisors / leaders / owners of the company.</li>
            </ul>

            <form method="post">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="Input.StudentEmail" class="form-label">Student Email</label>
                        <input asp-for="Input.StudentEmail" class="form-control" readonly />
                        <span asp-validation-for="Input.StudentEmail" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Input.CompanyName" class="form-label">Company Name</label>
                        <input asp-for="Input.CompanyName" class="form-control" />
                        <span asp-validation-for="Input.CompanyName" class="text-danger"></span>
                    </div>

                    <div class="col-12">
                        <label asp-for="Input.CompanyAddress" class="form-label">Company Address</label>
                        <textarea asp-for="Input.CompanyAddress" class="form-control" rows="3"></textarea>
                        <span asp-validation-for="Input.CompanyAddress" class="text-danger"></span>
                    </div>

                    <div class="col-12">
                        <div class="form-check">
                            <input asp-for="Input.ConfirmNoRelationship" class="form-check-input" />
                            <label asp-for="Input.ConfirmNoRelationship" class="form-check-label">
                                I confirm that I do not have any relationship with the managers / supervisors / leaders / owners of the company.
                            </label>
                        </div>
                        <span asp-validation-for="Input.ConfirmNoRelationship" class="text-danger"></span>
                    </div>
                </div>

                <div class="mt-3 d-flex gap-2">
                    <button type="submit" class="btn btn-primary">Submit Details</button>
                    <a asp-page="/Student/OwnCompanyRequest" class="btn btn-outline-secondary">Reset</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

@page
@model ITPSystem.Pages.Supervisor.StudentsModel
<h2>Student & Internship Tracking</h2>
<div class="mb-3">
    <a class="btn btn-outline-secondary btn-sm" asp-page="/Supervisor/Dashboard">Return to Dashboard</a>
</div>

<form method="get" class="row g-2 align-items-end mb-3">
    <div class="col-md-4">
        <label class="form-label">Filter by Academic Level</label>
        <select class="form-select form-select-sm" asp-for="level">
            <option value="">All Levels</option>
            <option value="1">1 - Diploma</option>
            <option value="2">2 - Degree</option>
            <option value="3">3 - Master</option>
            <option value="4">4 - PhD</option>
        </select>
    </div>
    <div class="col-md-2">
        <button type="submit" class="btn btn-primary btn-sm w-100">Apply</button>
    </div>
    <div class="col-md-2">
        <a class="btn btn-outline-secondary btn-sm w-100" asp-page="/Supervisor/Students">Reset</a>
    </div>
</form>

@if (!string.IsNullOrWhiteSpace(Model.Message))
{
    <div class="alert alert-info">@Model.Message</div>
}

<h5>Current Students</h5>
@if (!Model.CurrentStudents.Any())
{
    <div class="alert alert-info">No current students found for your filters.</div>
}
else
{
    <table class="table table-bordered table-sm">
        <thead>
            <tr>
                <th>Student</th>
                <th>Academic</th>
                <th>Level</th>
                <th>Company</th>
                <th>Allowance</th>
                <th>Supervisor</th>
                <th>Application Status</th>
                <th>Supervisor Remark</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var s in Model.CurrentStudents)
            {
                <tr>
                    <td>@s.studentName<br /><small>@s.studentID</small></td>
                    <td>CGPA: @(s.CGPA?.ToString("0.00") ?? "-")<br />Programme: @s.programme</td>
                    <td>@ITPSystem.Pages.Supervisor.StudentsModel.GetLevelLabel(s.level)</td>
                    <td>@(s.comName ?? "-")<br /><small>@(s.comAddress ?? "-")</small></td>
                    <td>@(s.allowance?.ToString("0.00") ?? "-")</td>
                    <td>@(s.comSupervisor ?? "-")<br /><small>@(s.ucSupervisor ?? "-")</small></td>
                    <td>
                        @if (string.Equals(s.applyStatus, "approved", System.StringComparison.OrdinalIgnoreCase))
                        {
                            <span class="badge bg-success">Approved</span>
                        }
                        else if (string.Equals(s.applyStatus, "rejected", System.StringComparison.OrdinalIgnoreCase))
                        {
                            <span class="badge bg-danger">Rejected</span>
                        }
                        else
                        {
                            <span class="badge bg-warning text-dark">Pending</span>
                        }
                    </td>
                    <td>@(string.IsNullOrWhiteSpace(s.remark) ? "-" : s.remark)</td>
                    <td>
                        <a class="btn btn-outline-primary btn-sm" asp-page="/Supervisor/Documents" asp-route-applicationId="@s.application_id">Documents</a>
                        <a class="btn btn-outline-primary btn-sm" asp-page="/Supervisor/ReportResults" asp-route-applicationId="@s.application_id">Reports</a>

                        <form method="post" class="mt-2 d-flex gap-1 align-items-center">
                            <input type="hidden" name="applicationId" value="@s.application_id" />
                            <select name="cohortId" class="form-select form-select-sm">
                                @foreach (var option in Model.CohortOptions)
                                {
                                    if (option.Value == s.cohortId.ToString())
                                    {
                                        <option value="@option.Value" selected>@option.Text</option>
                                    }
                                    else
                                    {
                                        <option value="@option.Value">@option.Text</option>
                                    }
                                }
                            </select>
                            <button type="submit" asp-page-handler="UpdateCohort" class="btn btn-outline-secondary btn-sm">Update Cohort</button>
                        </form>

                        @if (string.Equals(s.applyStatus, "pending", System.StringComparison.OrdinalIgnoreCase))
                        {
                            <form method="post" class="mt-2">
                                <input type="hidden" name="applicationId" value="@s.application_id" />
                                <input type="text" name="remarks" class="form-control form-control-sm mb-2" placeholder="Decision remark (optional)" />
                                <button type="submit" asp-page-handler="Approve" class="btn btn-success btn-sm me-1">Approve</button>
                                <button type="submit" asp-page-handler="Reject" class="btn btn-danger btn-sm">Reject</button>
                            </form>
                        }
                        else if (string.Equals(s.applyStatus, "rejected", System.StringComparison.OrdinalIgnoreCase))
                        {
                            <form method="post" class="mt-2">
                                <input type="hidden" name="applicationId" value="@s.application_id" />
                                <input type="text" name="remarks" class="form-control form-control-sm mb-2" placeholder="Approval remark (optional)" />
                                <button type="submit" asp-page-handler="Approve" class="btn btn-success btn-sm">Approve Again</button>
                            </form>
                        }
                        else if (string.Equals(s.applyStatus, "approved", System.StringComparison.OrdinalIgnoreCase))
                        {
                            <form method="post" class="mt-2">
                                <input type="hidden" name="applicationId" value="@s.application_id" />
                                <input type="text" name="remarks" class="form-control form-control-sm mb-2" placeholder="Rejection reason (required)" required />
                                <button type="submit" asp-page-handler="Reject" class="btn btn-danger btn-sm">Reject Approved Student</button>
                            </form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<h5>History Students</h5>
@if (!Model.HistoryStudents.Any())
{
    <div class="alert alert-info">No history students found for your filters.</div>
}
else
{
    var historyGroups = Model.HistoryStudents
        .GroupBy(s => s.cohortId)
        .OrderByDescending(g => Model.GetCohortStartDate(g.Key) ?? DateTime.MinValue)
        .ToList();

    foreach (var group in historyGroups)
    {
        <h6 class="mt-3">@Model.GetCohortHeader(group.Key)</h6>
        <table class="table table-bordered table-sm">
            <thead>
                <tr>
                    <th>Student</th>
                    <th>Academic</th>
                    <th>Level</th>
                    <th>Company</th>
                    <th>Allowance</th>
                    <th>Supervisor</th>
                    <th>Application Status</th>
                    <th>Supervisor Remark</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var s in group)
                {
                    <tr>
                        <td>@s.studentName<br /><small>@s.studentID</small></td>
                        <td>CGPA: @(s.CGPA?.ToString("0.00") ?? "-")<br />Programme: @s.programme</td>
                        <td>@ITPSystem.Pages.Supervisor.StudentsModel.GetLevelLabel(s.level)</td>
                        <td>@(s.comName ?? "-")<br /><small>@(s.comAddress ?? "-")</small></td>
                        <td>@(s.allowance?.ToString("0.00") ?? "-")</td>
                        <td>@(s.comSupervisor ?? "-")<br /><small>@(s.ucSupervisor ?? "-")</small></td>
                        <td>
                            @if (string.Equals(s.applyStatus, "approved", System.StringComparison.OrdinalIgnoreCase))
                            {
                                <span class="badge bg-success">Approved</span>
                            }
                            else if (string.Equals(s.applyStatus, "rejected", System.StringComparison.OrdinalIgnoreCase))
                            {
                                <span class="badge bg-danger">Rejected</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">Pending</span>
                            }
                        </td>
                        <td>@(string.IsNullOrWhiteSpace(s.remark) ? "-" : s.remark)</td>
                        <td>
                            <a class="btn btn-outline-primary btn-sm" asp-page="/Supervisor/Documents" asp-route-applicationId="@s.application_id">Documents</a>
                            <a class="btn btn-outline-primary btn-sm" asp-page="/Supervisor/ReportResults" asp-route-applicationId="@s.application_id">Reports</a>

                            <form method="post" class="mt-2 d-flex gap-1 align-items-center">
                                <input type="hidden" name="applicationId" value="@s.application_id" />
                                <select name="cohortId" class="form-select form-select-sm">
                                    @foreach (var option in Model.CohortOptions)
                                    {
                                        if (option.Value == s.cohortId.ToString())
                                        {
                                            <option value="@option.Value" selected>@option.Text</option>
                                        }
                                        else
                                        {
                                            <option value="@option.Value">@option.Text</option>
                                        }
                                    }
                                </select>
                                <button type="submit" asp-page-handler="UpdateCohort" class="btn btn-outline-secondary btn-sm">Update Cohort</button>
                            </form>

                            @if (string.Equals(s.applyStatus, "pending", System.StringComparison.OrdinalIgnoreCase))
                            {
                                <form method="post" class="mt-2">
                                    <input type="hidden" name="applicationId" value="@s.application_id" />
                                    <input type="text" name="remarks" class="form-control form-control-sm mb-2" placeholder="Decision remark (optional)" />
                                    <button type="submit" asp-page-handler="Approve" class="btn btn-success btn-sm me-1">Approve</button>
                                    <button type="submit" asp-page-handler="Reject" class="btn btn-danger btn-sm">Reject</button>
                                </form>
                            }
                            else if (string.Equals(s.applyStatus, "rejected", System.StringComparison.OrdinalIgnoreCase))
                            {
                                <form method="post" class="mt-2">
                                    <input type="hidden" name="applicationId" value="@s.application_id" />
                                    <input type="text" name="remarks" class="form-control form-control-sm mb-2" placeholder="Approval remark (optional)" />
                                    <button type="submit" asp-page-handler="Approve" class="btn btn-success btn-sm">Approve Again</button>
                                </form>
                            }
                            else if (string.Equals(s.applyStatus, "approved", System.StringComparison.OrdinalIgnoreCase))
                            {
                                <form method="post" class="mt-2">
                                    <input type="hidden" name="applicationId" value="@s.application_id" />
                                    <input type="text" name="remarks" class="form-control form-control-sm mb-2" placeholder="Rejection reason (required)" required />
                                    <button type="submit" asp-page-handler="Reject" class="btn btn-danger btn-sm">Reject Approved Student</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
}

@page
@model ITPSystem.Pages.Supervisor.DocumentsModel
<h2>Document Review</h2>
@if (!string.IsNullOrWhiteSpace(Model.SelectedStudent))
{
    <p class="text-muted">Showing documents for: <strong>@Model.SelectedStudent</strong></p>
}
<div class="mb-3">
    <a class="btn btn-outline-secondary btn-sm" asp-page="/Supervisor/Dashboard">Back to Dashboard</a>
    <a class="btn btn-outline-secondary btn-sm" asp-page="/Supervisor/Students">Back to Student Tracking</a>
</div>

@if (!string.IsNullOrWhiteSpace(Model.Message))
{
    <div class="alert alert-success">@Model.Message</div>
}

<table class="table table-bordered table-sm">
    <thead>
        <tr>
            <th>Student</th>
            <th>Company</th>
            <th>Acceptance</th>
            <th>Acknowledgement</th>
            <th>Final/Other</th>
            <th>Action</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var s in Model.Students)
        {
            <tr>
                <td>@s.studentName (@s.studentID)</td>
                <td>@s.comName</td>
                <td>
                    @if (!string.IsNullOrWhiteSpace(s.formAcceptance))
                    {
                        <div>@s.formAcceptance</div>
                        <div class="d-flex gap-2 mt-1">
                            <a asp-page-handler="View" asp-route-applicationId="@s.application_id" asp-route-documentType="formAcceptance" target="_blank" rel="noopener">View</a>
                            <a asp-page-handler="Download" asp-route-applicationId="@s.application_id" asp-route-documentType="formAcceptance">Download</a>
                        </div>
                    }
                    else
                    {
                        <span>-</span>
                    }
                </td>
                <td>
                    @if (!string.IsNullOrWhiteSpace(s.formAcknowledgement))
                    {
                        <div>@s.formAcknowledgement</div>
                        <div class="d-flex gap-2 mt-1">
                            <a asp-page-handler="View" asp-route-applicationId="@s.application_id" asp-route-documentType="formAcknowledgement" target="_blank" rel="noopener">View</a>
                            <a asp-page-handler="Download" asp-route-applicationId="@s.application_id" asp-route-documentType="formAcknowledgement">Download</a>
                        </div>
                    }
                    else
                    {
                        <span>-</span>
                    }
                </td>
                <td>
                    <div><strong>Letter:</strong> @(s.letterIdentity ?? "-")</div>
                    @if (!string.IsNullOrWhiteSpace(s.letterIdentity))
                    {
                        <div class="d-flex gap-2 mt-1 mb-1">
                            <a asp-page-handler="View" asp-route-applicationId="@s.application_id" asp-route-documentType="letterIdentity" target="_blank" rel="noopener">View</a>
                            <a asp-page-handler="Download" asp-route-applicationId="@s.application_id" asp-route-documentType="letterIdentity">Download</a>
                        </div>
                    }

                    <div><strong>Other:</strong> @(s.otherEvidence ?? "-")</div>
                    @if (!string.IsNullOrWhiteSpace(s.otherEvidence))
                    {
                        <div class="d-flex gap-2 mt-1">
                            <a asp-page-handler="View" asp-route-applicationId="@s.application_id" asp-route-documentType="otherEvidence" target="_blank" rel="noopener">View</a>
                            <a asp-page-handler="Download" asp-route-applicationId="@s.application_id" asp-route-documentType="otherEvidence">Download</a>
                        </div>
                    }
                </td>
                <td>
                    <form method="post" class="d-flex gap-1">
                        <input type="hidden" name="applicationId" value="@s.application_id" />
                        <input type="text" name="remarks" class="form-control form-control-sm" placeholder="Application review remark" />
                        <button class="btn btn-success btn-sm" asp-page-handler="Approve" type="submit">Approve Application</button>
                        <button class="btn btn-danger btn-sm" asp-page-handler="Reject" type="submit">Reject Application</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>

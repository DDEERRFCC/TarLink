@page
@model ITPSystem.Pages.Supervisor.NotificationsModel
<h2>My Notifications</h2>

<div class="mb-3">
    <a class="btn btn-outline-secondary btn-sm" asp-page="/Supervisor/Dashboard">Return to Dashboard</a>
</div>

<form method="post" asp-page-handler="MarkAllRead" class="mb-3">
    <button class="btn btn-outline-secondary btn-sm" type="submit">Mark All As Read</button>
</form>

<table class="table table-bordered table-sm">
    <thead>
        <tr>
            <th>Date</th>
            <th>Type</th>
            <th>Title</th>
            <th>Message</th>
            <th>Status</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var n in Model.Items)
        {
            <tr>
                <td>@n.created_at.ToString("yyyy-MM-dd HH:mm")</td>
                <td>@n.type</td>
                <td>@n.title</td>
                <td>@n.message</td>
                <td>@(n.is_read ? "Read" : "Unread")</td>
            </tr>
        }
    </tbody>
</table>

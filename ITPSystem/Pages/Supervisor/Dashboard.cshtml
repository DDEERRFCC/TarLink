@page
@model ITPSystem.Pages.Supervisor.DashboardModel
<h2>Supervisor Dashboard</h2>
<p>Welcome, @Model.UserName!</p>

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card"><div class="card-body"><strong>@Model.PendingReports</strong><br />Pending Reports</div></div>
    </div>
    <div class="col-md-3">
        <div class="card"><div class="card-body"><strong>@Model.PendingDocuments</strong><br />Pending Documents</div></div>
    </div>
    <div class="col-md-3">
        <div class="card"><div class="card-body"><strong>@Model.ActiveInternships</strong><br />Active Internships</div></div>
    </div>
    <div class="col-md-3">
        <div class="card"><div class="card-body"><strong>@Model.UnreadNotifications</strong><br />Unread Notifications</div></div>
    </div>
</div>

<div class="d-flex flex-wrap gap-2 mb-4">
    <a class="btn btn-primary" asp-page="/Supervisor/Reports">Progress Reports</a>
    <a class="btn btn-primary" asp-page="/Supervisor/Documents">Documents</a>
    <a class="btn btn-primary" asp-page="/Supervisor/Students">Student Tracking</a>
    <a class="btn btn-primary" asp-page="/Supervisor/Marks">Assessment Marks</a>
    <a class="btn btn-outline-secondary" asp-page="/Supervisor/Notifications">Notifications</a>
</div>

<h5>My Assigned Students</h5>
<table class="table table-sm table-bordered">
    <thead>
        <tr>
            <th>Student</th>
            <th>ID</th>
            <th>Company</th>
            <th>Cohort</th>
            <th>Status</th>
            <th>Allowance</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var s in Model.Students)
        {
            <tr>
                <td>@s.studentName</td>
                <td>@s.studentID</td>
                <td>@(string.IsNullOrWhiteSpace(s.comName) ? "-" : s.comName)</td>
                <td>@s.cohortId</td>
                <td>@s.applyStatus</td>
                <td>@(s.allowance?.ToString("0.00") ?? "-")</td>
            </tr>
        }
    </tbody>
</table>

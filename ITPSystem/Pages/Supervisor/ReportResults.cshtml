@page
@model ITPSystem.Pages.Supervisor.ReportResultsModel
<h2>Progress Report Results</h2>
<p class="text-muted">See report decisions for each student report (approved/rejected/submitted).</p>

<div class="mb-3 d-flex gap-2">
    <a class="btn btn-outline-secondary btn-sm" asp-page="/Supervisor/Dashboard">Back to Dashboard</a>
    @if (Model.applicationId.HasValue)
    {
        <a class="btn btn-outline-secondary btn-sm" asp-page="/Supervisor/ReportResults">Clear Student Filter</a>
    }
</div>

@if (!string.IsNullOrWhiteSpace(Model.SelectedStudent))
{
    <p class="text-muted">Showing reports for: <strong>@Model.SelectedStudent</strong></p>
}

@if (!string.IsNullOrWhiteSpace(Model.Message))
{
    <div class="alert alert-success">@Model.Message</div>
}

<form method="get" class="row g-2 align-items-end mb-3">
    <div class="col-md-4">
        <label class="form-label">Filter by Report Progress</label>
        <select asp-for="reportFilter" class="form-select form-select-sm">
            <option value="all">All Reports</option>
            <option value="p1">Progress Report 1</option>
            <option value="p2">Progress Report 2</option>
            <option value="p3">Progress Report 3</option>
            <option value="p4">Progress Report 4</option>
            <option value="p5">Progress Report 5</option>
            <option value="p6">Progress Report 6</option>
            <option value="f">Final Report</option>
        </select>
    </div>
    @if (Model.applicationId.HasValue)
    {
        <input type="hidden" name="applicationId" value="@Model.applicationId.Value" />
    }
    <div class="col-md-2">
        <button type="submit" class="btn btn-primary btn-sm w-100">Apply</button>
    </div>
</form>

@if (!Model.StudentSummaries.Any())
{
    <div class="alert alert-info">No report records found for your assigned students.</div>
}
else
{
    <table class="table table-bordered table-sm">
        <thead>
            <tr>
                <th>Student</th>
                <th>Report</th>
                <th>Due Date</th>
                <th>Status</th>
                <th>Last Updated</th>
                <th>Remark</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var student in Model.StudentSummaries)
            {
                @for (var i = 0; i < student.ReportItems.Count; i++)
                {
                    var item = student.ReportItems[i];
                    <tr>
                        @if (i == 0)
                        {
                            <td rowspan="@student.ReportItems.Count">@student.StudentName (@student.StudentId)</td>
                        }
                        <td>
                            <a asp-page="/Supervisor/ReportView" asp-route-reportId="@item.Report.report_id" asp-route-applicationId="@item.Report.applicantId">
                                @Model.GetReportTitle(item.Report)
                            </a>
                        </td>
                        <td>@item.Report.dueDate.ToString("yyyy-MM-dd")</td>
                        <td><span class="badge @Model.GetStatusBadgeClass(item.Report.status)">@Model.GetStatusLabel(item.Report.status)</span></td>
                        <td>@item.Report.updated_at.ToString("yyyy-MM-dd HH:mm")</td>
                        <td>@(string.IsNullOrWhiteSpace(item.Report.remark) ? "-" : item.Report.remark)</td>
                        <td>
                            @if (item.Report.status == 1)
                            {
                                <form method="post" class="d-flex gap-1">
                                    <input type="hidden" name="reportId" value="@item.Report.report_id" />
                                    <input type="hidden" name="applicationId" value="@item.Report.applicantId" />
                                    <input type="hidden" name="reportFilter" value="@Model.reportFilter" />
                                    <input type="text" name="remarks" class="form-control form-control-sm" placeholder="Remarks" />
                                    <button class="btn btn-success btn-sm" type="submit" asp-page-handler="Approve">Approve</button>
                                    <button class="btn btn-danger btn-sm" type="submit" asp-page-handler="Reject">Reject</button>
                                </form>
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
}

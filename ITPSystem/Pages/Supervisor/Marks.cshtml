@page
@model ITPSystem.Pages.Supervisor.MarksModel
<h2>Assessment Mark Sheet</h2>

@if (!string.IsNullOrWhiteSpace(Model.Message))
{
    <div class="alert alert-success">@Model.Message</div>
}

<form method="post" class="row g-2 align-items-end mb-4">
    <div class="col-md-3">
        <label class="form-label">Student</label>
        <select name="applicationId" class="form-select" required>
            <option value="">Select student</option>
            @foreach (var s in Model.Students)
            {
                <option value="@s.application_id">@s.studentName (@s.studentID)</option>
            }
        </select>
    </div>
    <div class="col-md-3">
        <label class="form-label">Rubric Item</label>
        <input class="form-control" name="rubricItem" required />
    </div>
    <div class="col-md-2">
        <label class="form-label">Score</label>
        <input class="form-control" name="score" type="number" step="0.01" required />
    </div>
    <div class="col-md-2">
        <label class="form-label">Max Score</label>
        <input class="form-control" name="maxScore" type="number" step="0.01" required />
    </div>
    <div class="col-md-2">
        <button class="btn btn-primary w-100" type="submit">Save Mark</button>
    </div>
    <div class="col-12">
        <label class="form-label">Remarks</label>
        <input class="form-control" name="remarks" />
    </div>
</form>

<table class="table table-bordered table-sm">
    <thead>
        <tr>
            <th>Student</th>
            <th>Rubric</th>
            <th>Score</th>
            <th>Remarks</th>
            <th>Date</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.MarkItems)
        {
            <tr>
                <td>@item.StudentName</td>
                <td>@item.Mark.rubric_item</td>
                <td>@item.Mark.score / @item.Mark.max_score</td>
                <td>@item.Mark.remarks</td>
                <td>@item.Mark.created_at.ToString("yyyy-MM-dd")</td>
            </tr>
        }
    </tbody>
</table>

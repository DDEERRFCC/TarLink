@page
@model CommitteeLoginModel
@{
    ViewData["Title"] = "Committee Login - ITPSystem";
}

<style>
    .login-wrap {
        min-height: calc(100vh - 80px);
        background:
            radial-gradient(circle at 12% 8%, rgba(100, 116, 139, .18), transparent 28%),
            radial-gradient(circle at 85% 15%, rgba(99, 102, 241, .12), transparent 25%),
            linear-gradient(160deg, #f5f6fb, #eceff8);
        padding: 2rem 0 2.5rem;
    }

    .login-card {
        border: 1px solid #d7ddee;
        border-radius: 16px;
        box-shadow: 0 16px 36px rgba(15, 23, 42, .12);
        overflow: hidden;
    }

    .login-head {
        background: linear-gradient(120deg, #334155, #4338ca);
        color: #fff;
        padding: 1rem 1.1rem;
    }

    .back-arrow {
        color: #fff;
        text-decoration: none;
        font-weight: 700;
        font-size: .92rem;
    }

    .back-arrow:hover {
        color: #e2e8f0;
    }
</style>

<div class="login-wrap">
    <div class="container" style="max-width: 430px;">
        <div class="login-card bg-white">
            <div class="login-head d-flex justify-content-between align-items-center">
                <div>
                    <div style="font-size:.8rem;opacity:.88;">ITP Portal</div>
                    <h4 class="mb-0">Committee Login</h4>
                </div>
                <a class="back-arrow" asp-page="/Index">← Back</a>
            </div>

            <div class="card-body p-4">
                @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                {
                    <div class="alert alert-danger">@Model.ErrorMessage</div>
                }

                <form method="post">
                    <div class="mb-3">
                        <label class="form-label">Email or Username</label>
                        <input type="text" asp-for="Email" class="form-control" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Password</label>
                        <input type="password" asp-for="Password" class="form-control" required />
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <a asp-page="/Login/ForgotPassword">Forgot Password?</a>
                    </div>

                    <button type="submit" class="btn btn-secondary w-100">Login</button>
                </form>
            </div>
        </div>
    </div>
</div>
